<dialog
  data-controller="form-modal"
  data-action="click->form-modal#backdropClick"
  class="rounded-xl shadow-2xl p-0 border-0 backdrop:bg-stone-900/60 backdrop:backdrop-blur-sm"
  style="width: min(90vw, 28rem); position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); margin: 0; padding: 0;">

  <div style="padding: 2rem 2rem 1.75rem;">
    <%# ── ヘッダー ── %>
    <div class="flex items-start justify-between mb-5">
      <div>
        <p class="text-xs font-bold tracking-[0.3em] text-teal-600 uppercase mb-2">Contact</p>
        <h2 class="font-serif text-2xl font-bold text-stone-900">お問い合わせ</h2>
      </div>
      <button
        type="button"
        data-action="form-modal#close"
        class="text-stone-400 hover:text-stone-600 transition-colors mt-1 text-lg leading-none p-1">
        ✕
      </button>
    </div>

    <p class="text-stone-500 text-sm mb-6">資料請求やご質問はこちらからお気軽にどうぞ。</p>

    <%# ── フォーム ── %>
    <%= form_with scope: :form_submission, url: "#", method: :post, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :name, "お名前", class: "block text-sm font-medium text-stone-700 mb-1.5" %>
        <%= f.text_field :name,
              placeholder: "山田 太郎",
              class: "block w-full border border-stone-300 rounded-lg px-3.5 py-2.5 text-sm
                      focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent
                      placeholder:text-stone-300 transition" %>
      </div>
      <div>
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-stone-700 mb-1.5" %>
        <%= f.email_field :email,
              placeholder: "you@example.com",
              class: "block w-full border border-stone-300 rounded-lg px-3.5 py-2.5 text-sm
                      focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent
                      placeholder:text-stone-300 transition" %>
      </div>
      <div class="pt-1">
        <%= f.submit "送信する",
              class: "w-full bg-stone-900 text-white text-sm font-medium py-3 rounded-lg
                      hover:bg-stone-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</dialog>

<style>
  dialog[open] {
    animation: fadeSlideUp 0.3s ease-out;
    background: white;
  }
  dialog::backdrop {
    background: rgba(28, 25, 23, 0.65);
    backdrop-filter: blur(2px);
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translate(-50%, calc(-50% + 12px)); }
    to   { opacity: 1; transform: translate(-50%, -50%); }
  }
</style>
