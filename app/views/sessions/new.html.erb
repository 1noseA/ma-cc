<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="mb-8">
      <p class="text-xs font-bold tracking-[0.3em] text-teal-600 uppercase mb-3">Admin</p>
      <h1 class="font-serif text-3xl font-bold text-stone-900">ログイン</h1>
    </div>

    <%= form_with url: session_url, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "メールアドレス", class: "block text-sm font-medium text-stone-700 mb-1.5" %>
        <%= form.email_field :email_address,
              required: true,
              autofocus: true,
              autocomplete: "username",
              value: params[:email_address],
              class: "block w-full border border-stone-300 rounded px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition" %>
      </div>

      <div>
        <%= form.label :password, "パスワード", class: "block text-sm font-medium text-stone-700 mb-1.5" %>
        <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              maxlength: 72,
              class: "block w-full border border-stone-300 rounded px-3.5 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition" %>
      </div>

      <%= form.submit "ログイン", class: "w-full bg-stone-900 text-white text-sm font-medium py-2.5 rounded hover:bg-stone-700 transition-colors cursor-pointer" %>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to "パスワードを忘れた方", new_password_path, class: "text-sm text-stone-400 hover:text-stone-700 transition-colors" %>
    </div>
  </div>
</div>
