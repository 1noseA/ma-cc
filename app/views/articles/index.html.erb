<% content_for :title, "記事一覧" %>

<section class="py-12">
  <div class="flex items-baseline gap-4 mb-12">
    <h1 class="font-serif text-4xl font-bold text-stone-900">記事一覧</h1>
    <span class="text-stone-400 text-sm"><%= @articles.count %> 本</span>
  </div>

  <% if @articles.any? %>
    <ul class="divide-y divide-stone-200">
      <% @articles.each_with_index do |article, i| %>
        <li>
          <%= link_to article_path(article), class: "flex items-center gap-6 py-5 group -mx-2 px-2 hover:bg-stone-100/60 transition-colors rounded" do %>
            <span class="text-xs text-stone-300 font-mono w-6 shrink-0 select-none">
              <%= (i + 1).to_s.rjust(2, "0") %>
            </span>
            <span class="text-stone-800 group-hover:text-teal-700 font-medium transition-colors flex-1">
              <%= article.title %>
            </span>
            <span class="text-stone-300 group-hover:text-teal-500 transition-colors text-sm">→</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-stone-400 text-sm">記事はまだありません。</p>
  <% end %>
</section>
