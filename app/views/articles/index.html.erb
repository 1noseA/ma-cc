<% content_for :title, "記事一覧" %>

<section class="w-full">
  <h1 class="text-3xl font-bold mb-6">記事一覧</h1>

  <% if @articles.any? %>
    <ul class="space-y-3">
      <% @articles.each do |article| %>
        <li class="border-b pb-2">
          <%= link_to article.title, article_path(article), class: "text-blue-600 hover:underline text-lg" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-500">記事はまだありません。</p>
  <% end %>
</section>
