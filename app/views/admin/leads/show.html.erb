<% content_for :title, "#{@lead.name} - リード詳細" %>

<div class="mb-6">
  <%= link_to "← リード一覧", admin_leads_path, class: "text-stone-400 hover:text-stone-700 text-sm" %>
</div>

<h1 class="text-2xl font-bold mb-2"><%= @lead.name %></h1>
<p class="text-stone-500 text-sm mb-8"><%= @lead.email %></p>

<h2 class="text-lg font-semibold mb-3">行動履歴</h2>
<table class="w-full text-sm mb-10">
  <thead>
    <tr class="border-b">
      <th class="text-left py-2 pr-4">種別</th>
      <th class="text-left py-2 pr-4">パス</th>
      <th class="text-left py-2 pr-4">日時</th>
    </tr>
  </thead>
  <tbody>
    <% @lead.visitor.events.sort_by(&:occurred_at).reverse.each do |event| %>
      <tr class="border-b hover:bg-stone-50">
        <td class="py-2 pr-4"><%= event.event_type %></td>
        <td class="py-2 pr-4"><%= event.path %></td>
        <td class="py-2 pr-4"><%= event.occurred_at.strftime("%Y/%m/%d %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2 class="text-lg font-semibold mb-3">フォーム送信履歴</h2>
<table class="w-full text-sm mb-10">
  <thead>
    <tr class="border-b">
      <th class="text-left py-2 pr-4">メール</th>
      <th class="text-left py-2 pr-4">氏名</th>
      <th class="text-left py-2 pr-4">送信日時</th>
    </tr>
  </thead>
  <tbody>
    <% @lead.visitor.form_submissions.sort_by { |s| s.submitted_at || Time.at(0) }.reverse.each do |submission| %>
      <tr class="border-b hover:bg-stone-50">
        <td class="py-2 pr-4"><%= submission.email %></td>
        <td class="py-2 pr-4"><%= submission.name %></td>
        <td class="py-2 pr-4"><%= submission.submitted_at&.strftime("%Y/%m/%d %H:%M") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
