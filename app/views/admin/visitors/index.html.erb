<h1 class="text-2xl font-bold mb-4">訪問者一覧</h1>

<table class="w-full border-collapse">
  <thead>
    <tr class="border-b">
      <th class="text-left p-2">ID</th>
      <th class="text-left p-2">トークン</th>
      <th class="text-left p-2">PV数</th>
      <th class="text-left p-2">最終訪問</th>
      <th class="text-left p-2"></th>
    </tr>
  </thead>
  <tbody>
    <% @visitors.each do |visitor| %>
      <tr class="border-b">
        <td class="p-2"><%= visitor.id %></td>
        <td class="p-2"><%= visitor.visitor_token %></td>
        <td class="p-2"><%= visitor.page_view_count %></td>
        <td class="p-2"><%= visitor.last_visited_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td class="p-2"><%= link_to "詳細", admin_visitor_path(visitor) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
