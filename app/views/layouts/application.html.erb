<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} | MA Tool" : "MA Tool" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="MA Tool">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 font-sans">
    <header class="fixed top-0 inset-x-0 z-50 bg-stone-900 border-b border-stone-800">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <%= link_to root_path, class: "text-white font-bold text-xs tracking-[0.25em] uppercase hover:text-stone-300 transition-colors" do %>
          MA Tool
        <% end %>
        <nav class="flex items-center gap-8">
          <%= link_to "記事", articles_path, class: "text-stone-400 hover:text-white text-sm transition-colors" %>
        </nav>
      </div>
    </header>

    <% if flash[:alert] %>
      <div class="fixed top-14 inset-x-0 z-40 bg-red-50 border-b border-red-200">
        <div class="max-w-5xl mx-auto px-6 py-3 text-red-600 text-sm"><%= flash[:alert] %></div>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="fixed top-14 inset-x-0 z-40 bg-teal-50 border-b border-teal-200">
        <div class="max-w-5xl mx-auto px-6 py-3 text-teal-700 text-sm"><%= flash[:notice] %></div>
      </div>
    <% end %>

    <main class="max-w-5xl mx-auto px-6 pt-20 pb-20 flex flex-col min-h-screen">
      <%= yield %>
    </main>
  </body>
</html>
